{
  "name": "waterfall-dashboard-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Waterfall Management Dashboard SPA (doc 08). Dependency set locked by ADR-0016.",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/check-allowlist.mjs && tsc --noEmit && vite build && node scripts/check-bundle-size.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/check-allowlist.mjs && vitest run",
    "test:watch": "vitest",
    "check:orphan": "node scripts/check-no-orphan-ui.mjs",
    "e2e": "playwright test",
    "preview": "vite preview",
    "check:bundle": "node scripts/check-bundle-size.mjs",
    "check:allowlist": "node scripts/check-allowlist.mjs",
    "check:ci": "tsc --noEmit && vitest run && node scripts/check-allowlist.mjs && node scripts/check-no-orphan-ui.mjs && npm run build && node scripts/check-bundle-size.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "3.14.5",
    "qrcode": "1.5.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "7.18.1",
    "recharts": "3.9.2",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "playwright": "1.61.1",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vitest": "3.2.6"
  }
}
